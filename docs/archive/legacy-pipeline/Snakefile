rule promote_docling_to_silver:
    """
    Promote raw Docling output into a minimal Silver artifact.
    """
    input:
        raw_doc = RAW_ROOT / "docling" / "{work_id}.json"
    output:
        SILVER_ROOT / "{work_id}.json"
    log:
        "logs/promote_docling/{work_id}.log"
    shell:
        "mkdir -p logs/promote_docling && "
        "python src/scripts/promote_docling.py "
        "--work-id {wildcards.work_id} "
        "--docling {input.raw_doc} "
        "--output {output} "
        "> {log} 2>&1"

