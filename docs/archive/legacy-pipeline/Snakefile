rule validate:
    """
    Validate Silver artifacts before Gold indexing.
    """
    input:
        expand(str(SILVER_ROOT / "{work_id}.json"), work_id=WORK_IDS),
        overrides = OVERRIDES_DIR / "alignment.yaml",
        manifest = "manifest.jsonl",
    output:
        GOLD_ROOT / "validation.json"
    log:
        "logs/validate.log"
    run:
        shell(
            "mkdir -p logs && "
            "python src/scripts/validate_pipeline.py "
            "--silver-root {silver_root} "
            "--overrides {input.overrides} "
            "--manifest {input.manifest} "
            "--output {output} "
            "> {log} 2>&1",
            silver_root=str(SILVER_ROOT),
            log=str(log[0]),
        )


rule build_gold:
    """
    Placeholder rule that would vectorize and index Silver artifacts.
    Gold outputs live under data/04_gold/ and are fully regenerable from Silver.
    """
    input:
        expand(str(SILVER_ROOT / "{work_id}.json"), work_id=WORK_IDS),
        GOLD_ROOT / "validation.json"
    output:
        GOLD_ROOT / "vector_index.dummy"
    log:
        "logs/build_gold.log"
    run:
        out_path = Path(output[0])
        out_path.parent.mkdir(parents=True, exist_ok=True)
        out_path.write_text("gold layer scaffold\n", encoding="utf-8")
        Path(log[0]).parent.mkdir(parents=True, exist_ok=True)
        Path(log[0]).write_text("build_gold completed\n", encoding="utf-8")
