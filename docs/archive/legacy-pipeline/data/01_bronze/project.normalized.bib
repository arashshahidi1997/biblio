 author = {Antony, James W and Sch{\"o}nauer, Monika and Staresina, Bernhard P and Cairney, Scott A},
 journal = {Trends in neurosciences},
 number = {1},
 pages = {1--3},
 title = {Sleep Spindles and Memory Reprocessing},
 volume = {42},
 year = {2019}
}

