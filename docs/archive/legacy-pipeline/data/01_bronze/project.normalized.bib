 author = {Tucker, {\relax DM} and Brown, M and Luu, P and Holmes, {\relax MD}},
 journal = {Epilepsy \& Behavior},
 title = {Discharges in Ventromedial Frontal Cortex during Absence Spells},
 year = {2007}
}

