@article{yoderProjectionsAnterodorsalThalamus2011,
 abstract = {The neural representation of directional heading is encoded by a population of cells located in a circuit that includes the postsubiculum (PoS), anterodorsal thalamus (ADN), and lateral mammillary nuclei (LMN). Throughout this circuit, many cells rely on both movement- and landmark-related information to discharge as a function of the animal's directional heading. The PoS projects to both the ADN and LMN, and these connections may convey critical spatial information about landmarks, because lesions of the PoS disrupt landmark control in head direction (HD) cells and hippocampal place cells [Goodridge and Taube (1997) J Neurosci 17:9315-9330; Calton et al. (2003) J Neurosci 23:9719-9731]. The PoS {$\rightarrow$} ADN projection originates in the deep layers of PoS, but no studies have determined whether the PoS {$\rightarrow$} LMN projection originates from the same cells that project to ADN. To address this issue, two distinct cholera toxin-subunit B (CTB) fluorophore conjugates (Alexa Fluor 488 and Alexa Fluor 594) were injected into the LMN and ADN of the same rats, and PoS sections were examined for cell bodies containing either or both CTB conjugates. Results indicated that the PoS {$\rightarrow$} LMN projection originates exclusively from a thin layer of cells located superficial to the layer(s) of PoS {$\rightarrow$} ADN projection cells, with no overlap. To verify the laminar distribution and morphological characteristics of PoS {$\rightarrow$} LMN and PoS {$\rightarrow$} ADN cells, biotinylated dextran amine was injected into LMN or ADN of different rats, and tissue sections were counterstained with thionin. Results indicated that the PoS {$\rightarrow$} LMN projection arises from large pyramidal cells in layer IV, whereas the PoS {$\rightarrow$} ADN projection arises from a heterogeneous cell population in layers V/VI. This study provides the first evidence that the PoS {$\rightarrow$} ADN and PoS {$\rightarrow$} LMN projections arise from distinct, nonoverlapping cell layers in PoS. Functionally, the PoS may provide landmark information to HD cells in LMN.},
 address = {Department of Psychological and Brain Sciences, Center for Cognitive Neuroscience, Dartmouth College, Hanover, New Hampshire 03755, USA.},
 author = {Yoder, {\relax RM} and Taube, {\relax JS}},
 journal = {Hippocampus},
 number = {10},
 pages = {1062--1073},
 title = {Projections to the Anterodorsal Thalamus and Lateral Mammillary Nuclei Arise from Different Cell Populations within the Postsubiculum: Implications for the Control of Head Direction Cells.},
 volume = {21},
 year = {2011}
}

