@article{mak-mccullyDistributionAmplitudeIncidence2015,
 abstract = {K-complexes (KCs) are thought to play a key role in sleep homeostasis and memory consolidation; however, their generation and propagation remain unclear. The commonly held view from scalp EEG findings is that KCs are primarily generated in medial frontal cortex and propagate parietally, whereas an electrocorticography (ECOG) study suggested dorsolateral prefrontal generators and an absence of KCs in many areas. In order to resolve these differing views, we used unambiguously focal bipolar depth electrode recordings in~{\dots}},
