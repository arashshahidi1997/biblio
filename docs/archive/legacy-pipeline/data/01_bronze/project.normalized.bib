@article{xuShortcuttingSelfmotionSignals2024,
 abstract = {Animals navigate by learning the spatial layout of their environment. We investigated spatial learning of mice in an open maze where food was hidden in one of a hundred holes. Mice leaving from a stable entrance learned to efficiently navigate to the food without the need for landmarks. We developed a quantitative framework to reveal how the mice estimate the food location based on analyses of trajectories and active hole checks. After learning, the computed `target estimation vector' (TEV) closely approximated the mice's route and its hole check distribution. The TEV required learning both the direction and distance of the start to food vector, and our data suggests that different learning dynamics underlie these estimates. We propose that the TEV can be precisely connected to the properties of hippocampal place cells. Finally, we provide the first demonstration that, after learning the location of two food sites, the mice took a shortcut between the sites, demonstrating that they had generated a cognitive map.},
 author = {Xu, Jiayun and {Girardi-Schappo}, Mauricio and Beique, Jean-Claude and Longtin, Andr{\'e} and Maler, Leonard},
 doi = {10.7554/eLife.95764},
 editor = {Cowan, Noah J and Wassum, Kate M},
 file = {bib/pdfs/Xu et al. - 2024 - Shortcutting from self-motion signals reveals a cognitive map in mice.pdf},
 issn = {2050-084X},
 journal = {eLife},
 keywords = {active sensing,cognitive map,open maze,shortcut,spatial learning,trajectory analysis},
 month = {November},
 pages = {RP95764},
 publisher = {eLife Sciences Publications, Ltd},
 title = {Shortcutting from Self-Motion Signals Reveals a Cognitive Map in Mice},
 urldate = {2025-10-13},
 volume = {13},
 year = {2024}
}

