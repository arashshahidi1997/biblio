@article{mullerStimulusevokedPopulationResponse2014,
 abstract = {Propagating waves occur in many excitable media and were recently found in neural systems from retina to neocortex. While propagating waves are clearly present under anaesthesia, whether they also appear during awake and conscious states remains unclear. One possibility is that these waves are systematically missed in trial-averaged data, due to variability. Here we present a method for detecting propagating waves in noisy multichannel recordings. Applying this method to single-trial voltage-sensitive dye imaging data, we show {\dots}},
 author = {Muller, Lyle and Reynaud, Alexandre and Chavane, Fr{\'e}d{\'e}ric and Destexhe, Alain},
