 author = {Taylor, Jeremy A and Smith, Zachary Z and Barth, Daniel S},
 journal = {Journal of Neurophysiology},
 number = {5},
 pages = {1152--1167},
 title = {Spike-Wave Discharges in {{Sprague}}--{{Dawley}} Rats Reflect Precise Intra-and Interhemispheric Synchronization of Somatosensory Cortex},
 volume = {128},
 year = {2022}
}

