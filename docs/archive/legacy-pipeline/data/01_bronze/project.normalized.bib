@article{helfrichOldBrainsCome2018,
 abstract = {The coupled interaction between slow-wave oscillations and sleep spindles during non-rapid-eye-movement (NREM) sleep has been proposed to support memory consolidation. However, little evidence in humans supports this theory. Moreover, whether such dynamic coupling is impaired as a consequence of brain aging in later life, contributing to cognitive and memory decline, is unknown. Combining electroencephalography (EEG), structural MRI, and sleep-dependent memory assessment, we addressed these questions in~{\dots}},
